# ================================================
# Required: Supabase (free tier at supabase.com)
# Get these from: Project Settings -> API
# ================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ================================================
# Required: Google Gemini (free at aistudio.google.com/apikey)
# ================================================
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# ================================================
# Optional: Upstash Redis for production rate limiting
# (free tier at console.upstash.com). If unset, falls
# back to in-memory limiter (fine for local dev).
# ================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ================================================
# Optional: HuggingFace token (image gen fallback)
# ================================================
HUGGINGFACE_API_TOKEN=

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
