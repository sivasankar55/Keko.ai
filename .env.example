# ================================================
# Required: Supabase (free tier at supabase.com)
# Get these from: Project Settings -> API
# ================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ================================================
# Required: Google Gemini
# Free key at https://aistudio.google.com/apikey
# Used for both chat (gemini-2.0-flash) and embeddings
# (text-embedding-004) for the RAG document chat.
# ================================================
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# ================================================
# Optional: Groq
# Free key at https://console.groq.com/keys
# Adds Llama 3 / Mixtral models to the in-conversation
# model picker. Without this, only Gemini models show.
# ================================================
GROQ_API_KEY=

# ================================================
# Optional: Upstash Redis for production rate limiting
# Free tier at https://console.upstash.com
# Without these, the limiter falls back to in-memory
# (fine for local dev, not for multi-instance prod).
# ================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ================================================
# Optional: HuggingFace token (image generation fallback)
# Free at https://huggingface.co/settings/tokens
# Image generation primarily uses Pollinations.ai (no key).
# This is a backup if Pollinations is down or returns junk.
# ================================================
HUGGINGFACE_API_TOKEN=

# ================================================
# App URL — used for OAuth redirects, share links,
# and invite link generation. Set to your deployed
# domain in production (e.g. https://keko-ai.vercel.app).
# ================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
